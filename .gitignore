# =============================================================================
# FileManagerDaz .gitignore
# Tauri v2 (Rust + Svelte 5 + SQLite WAL) — Production-ready
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY — Signing Keys & Secrets (CRITICAL)
# ─────────────────────────────────────────────────────────────────────────────
# Tauri updater signing keys (generated by `tauri signer generate`)
*.key
*.key.pub
*.privkey
*.secret

# Environment variables (may contain API tokens, passwords)
.env
.env.*
!.env.example

# Certificates & keystores
*.pem
*.p12
*.pfx
*.crt
*.cer
*.jks
*.keystore

# ─────────────────────────────────────────────────────────────────────────────
# SQLite — Database & WAL Journal Files
# ─────────────────────────────────────────────────────────────────────────────
# Main database files (generated at runtime)
*.db
*.sqlite
*.sqlite3

# WAL mode journal files (created when PRAGMA journal_mode = WAL)
*.db-wal
*.db-shm
*.sqlite-wal
*.sqlite-shm

# SQLite rollback journals
*.db-journal
*.sqlite-journal

# ─────────────────────────────────────────────────────────────────────────────
# Rust / Cargo
# ─────────────────────────────────────────────────────────────────────────────
# Build output (all profiles: debug, release, etc.)
target/

# NOTE: Cargo.lock is INTENTIONALLY TRACKED (binary app, not a library)
# It ensures reproducible builds across CI and dev machines.

# Backup files from rustfmt / cargo fix
**/*.rs.bk

# Compiled object files
*.rlib
*.rmeta
*.d

# ─────────────────────────────────────────────────────────────────────────────
# Tauri v2
# ─────────────────────────────────────────────────────────────────────────────
# Rust build (redundant with target/ but explicit)
src-tauri/target/

# Auto-generated code (Tauri CLI v2)
src-tauri/gen/

# Windows installer tooling (downloaded by Tauri)
src-tauri/WixTools/

# Icon build artifacts
src-tauri/icons/*.ico.bak

# Bundle outputs (installers/packages)
*.msi
*.nsis
*.AppImage
*.deb
*.rpm
*.snap
*.flatpak
*.dmg

# ─────────────────────────────────────────────────────────────────────────────
# Node.js / npm / pnpm / yarn
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
.npm/
.yarn/
.pnpm-store/

# Package manager debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─────────────────────────────────────────────────────────────────────────────
# Vite / SvelteKit
# ─────────────────────────────────────────────────────────────────────────────
.vite/
.svelte-kit/
build/
dist/
.vercel/
.netlify/

# ─────────────────────────────────────────────────────────────────────────────
# TypeScript
# ─────────────────────────────────────────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo
vitest.config.ts.timestamp*

# ─────────────────────────────────────────────────────────────────────────────
# Testing / Coverage
# ─────────────────────────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ─────────────────────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ─────────────────────────────────────────────────────────────────────────────
# IDE / Editor
# ─────────────────────────────────────────────────────────────────────────────
.idea/
.fleet/
*.sublime-project
*.sublime-workspace
*.code-workspace

# VS Code — ignore all except shared settings
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Vim/Neovim swap files
*.swp
*.swo
*~

# ─────────────────────────────────────────────────────────────────────────────
# OS Generated Files
# ─────────────────────────────────────────────────────────────────────────────
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.fseventsd
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory

# ─────────────────────────────────────────────────────────────────────────────
# AI / Copilot / Session Files
# ─────────────────────────────────────────────────────────────────────────────
.claude/
.copilot/
.cursor/
resume-session.txt
*.session
codex-*.txt

# ─────────────────────────────────────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────────────────────────────────────
rustup-init.exe
*.bak
*.tmp
*.temp
*.orig
*.patch
