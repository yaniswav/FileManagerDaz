# =============================================================================
# FileManagerDaz .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Node.js / npm
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# -----------------------------------------------------------------------------
# Vite / SvelteKit
# -----------------------------------------------------------------------------
.vite/
.svelte-kit/
build/
dist/

# -----------------------------------------------------------------------------
# Rust / Cargo
# -----------------------------------------------------------------------------
target/
Cargo.lock
**/*.rs.bk

# -----------------------------------------------------------------------------
# Tauri
# -----------------------------------------------------------------------------
src-tauri/target/
src-tauri/WixTools/
src-tauri/icons/*.ico.bak

# Tauri bundle outputs
*.msi
*.exe
*.dmg
*.AppImage
*.deb
*.rpm
*.app

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Environment / Secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key

# -----------------------------------------------------------------------------
# Testing / Coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log

# -----------------------------------------------------------------------------
# Application Data (local development)
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db

# -----------------------------------------------------------------------------
# OS Generated
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Session / Development files
# -----------------------------------------------------------------------------
resume-session.txt
*.session
codex-*.txt

# -----------------------------------------------------------------------------
# Rust installer (should never be committed)
# -----------------------------------------------------------------------------
rustup-init.exe
.claude/
