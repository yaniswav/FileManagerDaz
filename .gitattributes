# =============================================================================
# FileManagerDaz .gitattributes
# =============================================================================

# Auto-detect text files and normalize line endings to LF
* text=auto

# -----------------------------------------------------------------------------
# Source Code
# -----------------------------------------------------------------------------
*.rs text diff=rust
*.ts text diff=typescript
*.js text
*.svelte text
*.html text diff=html
*.css text diff=css
*.json text
*.toml text
*.yaml text
*.yml text
*.md text diff=markdown

# -----------------------------------------------------------------------------
# Configuration
# -----------------------------------------------------------------------------
*.conf text
*.config text
.gitignore text
.gitattributes text
.editorconfig text
Makefile text

# -----------------------------------------------------------------------------
# Documentation
# -----------------------------------------------------------------------------
*.txt text
LICENSE text
README* text

# -----------------------------------------------------------------------------
# Scripts
# -----------------------------------------------------------------------------
*.sh text eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# -----------------------------------------------------------------------------
# Binary Files (no diff, no merge)
# -----------------------------------------------------------------------------
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.webp binary
*.svg text

*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.rar binary

*.exe binary
*.dll binary
*.so binary
*.dylib binary

*.sqlite binary
*.db binary

# -----------------------------------------------------------------------------
# Rust Lockfile (treat as binary for merge purposes)
# -----------------------------------------------------------------------------
Cargo.lock text -diff

# -----------------------------------------------------------------------------
# Node Lockfile
# -----------------------------------------------------------------------------
package-lock.json text -diff
